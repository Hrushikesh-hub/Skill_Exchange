<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="3dp"
    android:paddingHorizontal="4dp">

    <!-- Received message (left-aligned) -->
    <LinearLayout
        android:id="@+id/layoutReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tvReceivedMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_received"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvReceivedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Sent message (right-aligned) -->
    <LinearLayout
        android:id="@+id/layoutSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tvSentMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_sent"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@color/on_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvSentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginTop="2dp"
            android:layout_gravity="end"
            android:layout_marginEnd="4dp" />
    </LinearLayout>
</FrameLayout>
