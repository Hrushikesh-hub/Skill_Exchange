<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: Title + Match Score + Status + Urgency Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fix Leaking Roof"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMatchScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="XX% Match"
                android:visibility="gone"
                app:chipMinHeight="24dp"
                android:textSize="10sp"
                android:clickable="false" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Closed"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#757575"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipUrgency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Urgency"
                app:chipMinHeight="24dp"
                android:textSize="10sp"
                android:clickable="false" />
        </LinearLayout>

        <!-- Skill + Offers row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvSkill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masonry"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:textStyle="bold"
                android:background="#E3F2FD"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />

            <TextView
                android:id="@+id/tvOfferCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 offers"
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginStart="10dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvHours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~6h"
                android:textSize="13sp"
                android:textColor="#666" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Location"
            android:textSize="12sp"
            android:textColor="#888"
            android:layout_marginBottom="6dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description text..."
            android:textSize="13sp"
            android:textColor="#555"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
