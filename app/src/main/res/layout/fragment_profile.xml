<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="4dp"
        android:title="Profile" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar + name row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="32dp"
                    app:cardBackgroundColor="#1976D2">

                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:text="AB" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:text="Name" />

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:text="email@example.com" />

                    <TextView
                        android:id="@+id/tvMemberSince"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:text="Member since Jan 2026" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvStatPoints" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:text="0" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SP" android:textSize="11sp" android:textColor="#666" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvStatRating" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:text="0.0★" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rating" android:textSize="11sp" android:textColor="#666" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvStatSwaps" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="18sp" android:textStyle="bold" android:text="0" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Swaps" android:textSize="11sp" android:textColor="#666" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvStatReviews" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:text="0 reviews" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Reviews" android:textSize="11sp" android:textColor="#666" />
                </LinearLayout>
            </LinearLayout>

            <!-- Trust label -->
            <TextView
                android:id="@+id/tvTrustLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:text="New Worker" />

            <!-- Reliability progress -->
            <TextView
                android:id="@+id/tvReliabilityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#333"
                android:text="Reliability: 70%" />

            <ProgressBar
                android:id="@+id/progressReliability"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginBottom="16dp"
                android:max="100"
                android:progress="70" />

            <!-- Badges -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#333"
                android:text="Badges"
                android:layout_marginBottom="4dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/layoutBadges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true" />
            </HorizontalScrollView>

            <!-- Verification Section -->
            <!-- Unverified -->
            <LinearLayout
                android:id="@+id/layoutUnverified"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#FFF8E1"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Your profile is not yet verified"
                    android:textColor="#E65100"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestVerification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request Verification" />
            </LinearLayout>

            <!-- Pending chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipVerificationPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="⏳ Verification Pending"
                android:clickable="false"
                android:visibility="gone"
                app:chipBackgroundColor="#FFF9C4" />

            <!-- Verified chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipVerificationVerified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="✅ Verified Professional"
                android:clickable="false"
                android:visibility="gone"
                app:chipBackgroundColor="#E8F5E9" />

            <!-- Rejected -->
            <LinearLayout
                android:id="@+id/layoutRejected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#FFEBEE"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ Verification Rejected"
                    android:clickable="false"
                    app:chipBackgroundColor="#FFCDD2" />

                <TextView
                    android:id="@+id/tvRejectionNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#B71C1C"
                    android:layout_marginTop="4dp"
                    android:text="" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReapply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Reapply" />
            </LinearLayout>

            <!-- Editable fields -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:hint="Full Name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:hint="Phone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:hint="Village / Area">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVillage"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:hint="Primary Skill">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrimarySkill"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:hint="Bio">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:minLines="2" android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Available for work" android:textSize="15sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAvailable"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateProfile"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:text="Save Changes" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWalletFromProfile"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:text="My Wallet" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewHistory"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:text="Swap History" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:text="Settings" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="#D32F2F" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
